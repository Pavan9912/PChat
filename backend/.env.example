# Server Configurations
PORT=5000
NODE_ENV=development

# Database Configuration (MongoDB Atlas or Local MongoDB instance)
MONGO_URI=mongodb+srv://pavan:<password>@pchat.iwysrhp.mongodb.net/pchat?retryWrites=true&w=majority
# Local fallback: mongodb://127.0.0.1:27017/pchat

# JWT Secret Phrase
JWT_SECRET=your_super_secret_jwt_sign_key_change_this_in_production

# Frontend Client Address
CLIENT_URL=http://localhost:5173

# Cloudinary Media Storage Integration (Optional - Fallbacks to local serving automatically if empty)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Google OAuth Client ID for Backend Token Verification (Leave empty to use mock login)
GOOGLE_CLIENT_ID=
